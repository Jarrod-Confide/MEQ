# Copy to .env.local for local dev. In Vercel, set these on the project.

# Postgres connection string for EventFlow's Supabase contacts table.
# Read-only access is sufficient; MEQ never writes here.
DATABASE_URL=

# NextAuth — generate with `openssl rand -base64 32`
AUTH_SECRET=

# Google OAuth credentials (Google Cloud Console → APIs & Services → Credentials)
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-vercel-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
